              {"key": "Details[0][UnitId]", "value": "1"},
              {"key": "Details[0][ExpectedQty]", "value": "10"},
              {"key": "Details[0][ActualQty]", "value": "10"},
              {"key": "Details[1][ProductId]", "value": "2"},
              {"key": "Details[1][UnitId]", "value": "1"},
              {"key": "Details[1][ExpectedQty]", "value": "5"},
              {"key": "Details[1][ActualQty]", "value": "4"}
            ]},
            "url": {"raw": "{{base_url}}/customer/inventory/inbout-request/create"}
          }
        }
      ]
    },

    {
      "name": "6. Outbout Request",
      "item": [
        {
          "name": "list",
          "request": {
            "method": "POST", "header": [{"key": "Authorization","value": "Bearer {{token}}"}],
            "body": { "mode": "formdata", "formdata": [
              {"key": "RelatedId", "value": "1"},
