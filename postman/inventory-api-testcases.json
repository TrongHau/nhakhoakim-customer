              {"key": "lmstart", "value": "0"}
            ]},
            "url": {"raw": "{{base_url}}/customer/inventory/outbout-request/list"}
          }
        },
        {
          "name": "confirm",
          "request": {
            "method": "POST", "header": [{"key": "Authorization","value": "Bearer {{token}}"}],
            "body": { "mode": "formdata", "formdata": [
              {"key": "OutboutRequestId", "value": "1"}
            ]},
            "url": {"raw": "{{base_url}}/customer/inventory/outbout-request/confirm"}
          }
        }
      ]
    },

    {
